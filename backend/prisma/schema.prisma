generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  wallet          String   @unique // Hedera Account ID (0.0.xxx)
  name            String?
  publicKey       String?  @map("public_key") // Hedera public key (cached from Mirror Node)
  worldIdHash     String?  @unique @map("worldid_nullifier") // World ID nullifier hash
  worldIdVerified Boolean  @default(false) @map("worldid_verified")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Reward {
  id            String   @id @default(uuid())
  sightingId    String   @unique @map("sighting_id")
  wallet        String
  amount        Int      // token units (with decimals)
  transactionId String   @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("rewards")
}

model AuthChallenge {
  id        String   @id @default(uuid())
  wallet    String   // Hedera Account ID
  nonce     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("auth_challenges")
}
