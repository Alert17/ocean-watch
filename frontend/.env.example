VITE_GRAPHQL_URL=https://indexer.oceanwatch.xyz/graphql
# MSW only mocks same-origin `/graphql`. Remote URLs hit the real API.
# Set to false to disable the worker entirely.
VITE_USE_MSW=true

# WalletConnect (Hedera) — bouton « My account » dans l’en-tête
VITE_WALLETCONNECT_PROJECT_ID=
VITE_HEDERA_NETWORK=testnet
